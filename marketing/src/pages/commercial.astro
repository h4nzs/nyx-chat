---
import MainLayout from '../layouts/MainLayout.astro';
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { FiShield, FiLock, FiTerminal, FiMail, FiCheck, FiX, FiAlertTriangle } from 'react-icons/fi';

const { lang: propLang } = Astro.props;
const lang = propLang || Astro.currentLocale || getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('commercial:meta.title');
const description = t('commercial:meta.description');

const licenseSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "publisher": {
    "@type": "Organization",
    "name": "NYX Project",
    "logo": "https://nyx-app.my.id/pwa-192x192.png"
  }
});
---

<MainLayout title={title} description={description} canonicalUrl={Astro.url.pathname} schemaMarkup={licenseSchema}>
  <div class="min-h-screen pt-24 pb-16 px-4 md:px-8 max-w-7xl mx-auto">
    
    <!-- Hero Section -->
    <header class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-bold text-[#06b6d4] bg-[#06b6d4]/10 border border-[#06b6d4]/20 rounded-full tracking-widest uppercase">
        <FiShield size={14} /> {t('commercial:hero.badge')}
      </div>
      <h1 class="text-4xl md:text-6xl font-black tracking-tighter mb-6 bg-gradient-to-r from-white via-white to-gray-500 bg-clip-text text-transparent uppercase">
        {t('commercial:hero.title')}
      </h1>
      <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">
        {t('commercial:hero.subtitle')}
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-24">
      <!-- AGPL-3.0 Section -->
      <section class="card-neumorphic border-white/5 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-accent/50"></div>
        <div class="flex items-center gap-3 mb-6">
          <div class="p-2 bg-[#0d1322] rounded-lg border border-[#1e293b] text-accent">
            <FiLock size={24} />
          </div>
          <div>
            <div class="text-[10px] text-text-secondary font-mono tracking-widest uppercase opacity-60">{t('commercial:agpl.badge')}</div>
            <h2 class="text-2xl font-bold">{t('commercial:agpl.title')}</h2>
          </div>
        </div>
        <div class="space-y-4 text-text-secondary leading-relaxed">
          <p set:html={t('commercial:agpl.p1')}></p>
          <p set:html={t('commercial:agpl.p2')}></p>
          
          <div class="mt-8 p-4 bg-red-500/10 border border-red-500/20 rounded-xl">
            <h3 class="text-red-400 font-bold flex items-center gap-2 mb-2 text-sm uppercase tracking-wide">
              <FiAlertTriangle /> {t('commercial:agpl.warning_title')}
            </h3>
            <p class="text-xs text-red-200/70">{t('commercial:agpl.warning_desc')}</p>
          </div>
        </div>
      </section>

      <!-- Commercial / B2B Section -->
      <section class="card-neumorphic border-white/5 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1 h-full bg-[#06b6d4]"></div>
        <div class="flex items-center gap-3 mb-6">
          <div class="p-2 bg-[#0d1322] rounded-lg border border-[#1e293b] text-[#06b6d4]">
            <FiTerminal size={24} />
          </div>
          <div>
            <div class="text-[10px] text-[#06b6d4] font-mono tracking-widest uppercase">{t('commercial:hero.badge')}</div>
            <h2 class="text-2xl font-bold">{t('commercial:hero.enterprise')}</h2>
          </div>
        </div>
        <div class="space-y-6">
          <p class="text-text-secondary leading-relaxed">
            {t('commercial:compare.col2_desc')}
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm font-medium">
              <FiCheck className="text-[#06b6d4]" /> {t('commercial:compare.f1')}
            </li>
            <li class="flex items-center gap-3 text-sm font-medium">
              <FiCheck className="text-[#06b6d4]" /> {t('commercial:compare.f3')}
            </li>
            <li class="flex items-center gap-3 text-sm font-medium">
              <FiCheck className="text-[#06b6d4]" /> {t('commercial:compare.f4')}
            </li>
            <li class="flex items-center gap-3 text-sm font-medium text-[#06b6d4]">
              <FiCheck /> {t('commercial:compare.val_com_f2')}
            </li>
          </ul>
          <a href="mailto:support@nyx-app.my.id" class="btn-primary w-full py-4 mt-4 shadow-[0_0_20px_rgba(6,182,212,0.15)] hover:shadow-[0_0_30px_rgba(6,182,212,0.3)] transition-all">
            <FiMail className="mr-2" /> {t('commercial:cta.button')}
          </a>
        </div>
      </section>
    </div>

    <!-- Comparison Table -->
    <section class="mb-24 overflow-hidden">
      <div class="text-center mb-12">
        <div class="inline-block px-3 py-1 mb-4 text-[10px] font-bold text-text-secondary bg-white/5 border border-white/10 rounded-full tracking-widest uppercase">
          {t('commercial:compare.badge')}
        </div>
        <h2 class="text-3xl font-bold">{t('commercial:compare.title')}</h2>
      </div>
      
      <div class="card-neumorphic p-0 overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-white/5">
              <th class="p-6 text-sm uppercase tracking-widest text-text-secondary">{t('commercial:compare.feature')}</th>
              <th class="p-6 text-sm font-bold text-accent">{t('commercial:compare.col1_title')}</th>
              <th class="p-6 text-sm font-bold text-[#06b6d4]">{t('commercial:compare.col2_title')}</th>
            </tr>
          </thead>
          <tbody class="text-sm">
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="p-6 font-medium">{t('commercial:compare.f1')}</td>
              <td class="p-6"><FiCheck className="text-accent" /></td>
              <td class="p-6"><FiCheck className="text-[#06b6d4]" /></td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="p-6 font-medium">{t('commercial:compare.f2')}</td>
              <td class="p-6 text-red-400/70">{t('commercial:compare.val_agpl_f2')}</td>
              <td class="p-6 text-[#06b6d4] font-bold">{t('commercial:compare.val_com_f2')}</td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="p-6 font-medium">{t('commercial:compare.f3')}</td>
              <td class="p-6"><FiX className="text-text-secondary opacity-30" /></td>
              <td class="p-6"><FiCheck className="text-[#06b6d4]" /></td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="p-6 font-medium">{t('commercial:compare.f5')}</td>
              <td class="p-6 text-text-secondary opacity-50">{t('commercial:compare.val_agpl_f5')}</td>
              <td class="p-6 text-[#06b6d4] font-bold">{t('commercial:compare.val_com_f5')}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Use Cases -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <div class="inline-block px-3 py-1 mb-4 text-[10px] font-bold text-text-secondary bg-white/5 border border-white/10 rounded-full tracking-widest uppercase">
          {t('commercial:usecases.badge')}
        </div>
        <h2 class="text-3xl font-bold">{t('commercial:usecases.title')}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card-neumorphic hover:-translate-y-1 transition-transform border-white/5">
          <h3 class="font-bold mb-3 text-accent">{t('commercial:usecases.c1_title')}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{t('commercial:usecases.c1_desc')}</p>
        </div>
        <div class="card-neumorphic hover:-translate-y-1 transition-transform border-white/5">
          <h3 class="font-bold mb-3 text-[#2563eb]">{t('commercial:usecases.c2_title')}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{t('commercial:usecases.c2_desc')}</p>
        </div>
        <div class="card-neumorphic hover:-translate-y-1 transition-transform border-white/5">
          <h3 class="font-bold mb-3 text-[#06b6d4]">{t('commercial:usecases.c3_title')}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{t('commercial:usecases.c3_desc')}</p>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="card-neumorphic bg-gradient-to-br from-[#0d1322] to-[#070a13] border-accent/20 text-center p-12 overflow-hidden relative">
      <div class="absolute inset-0 bg-[url('/noise.png')] opacity-10 pointer-events-none"></div>
      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-black mb-4">{t('commercial:cta.title')}</h2>
        <p class="text-text-secondary mb-8 max-w-2xl mx-auto">{t('commercial:cta.subtitle')}</p>
        <a href="mailto:support@nyx-app.my.id" class="btn-primary px-8 py-4 text-lg">
          {t('commercial:cta.button')}
        </a>
      </div>
    </section>

  </div>
</MainLayout>
/MainLayout>
out>
