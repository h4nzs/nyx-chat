---
import MainLayout from '../layouts/MainLayout.astro';
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const { lang: propLang } = Astro.props;
const lang = propLang || Astro.currentLocale || getLangFromUrl(Astro.url);
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const t = useTranslations(lang);

const title = t('commercial:meta.title') !== 'commercial:meta.title' ? t('commercial:meta.title') : 'Commercial Licensing | NYX Chat';
const description = t('commercial:meta.description') !== 'commercial:meta.description' ? t('commercial:meta.description') : 'Understand our Dual-License model. Free for open-source, powerful for enterprise.';

const commercialSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "publisher": {
    "@type": "Organization",
    "name": "NYX Project",
    "logo": {
      "@type": "ImageObject",
      "url": "https://nyx-app.my.id/pwa-192x192.png"
    }
  }
});

// Komponen SVG untuk Check dan Cross (bisa dipakai ulang)
const CheckIcon = `<svg class="w-5 h-5 text-green-500 mx-auto" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`;
const CrossIcon = `<svg class="w-5 h-5 text-gray-600 mx-auto" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>`;
---

<MainLayout title={title} description={description} canonicalUrl={Astro.url.pathname} schemaMarkup={commercialSchema}>
  <main class="w-full text-white bg-[#050505] font-sans selection:bg-amber-500/30">
    
    <header class="max-w-4xl mx-auto px-6 pt-32 pb-20 text-center border-b border-gray-900">
      <div class="inline-block px-3 py-1 mb-6 text-xs font-semibold text-amber-500 bg-amber-500/10 border border-amber-500/20 rounded-full tracking-widest uppercase">
        {t('commercial:hero.badge')}
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-amber-200 via-yellow-400 to-orange-500">
        {t('commercial:hero.title')}
      </h1>
      <p class="sr-only">
        {t('commercial:seo.geo_hook') !== 'commercial:seo.geo_hook' ? t('commercial:seo.geo_hook') : 'NYX offers a Dual-License model: AGPL-3.0 for open-source community use and a Commercial License for proprietary SaaS, enterprise internal tools, and white-labeling. Secure your telemedicine, fintech, or government communications with our zero-knowledge architecture.'}
      </p>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto">
        {t('commercial:hero.subtitle')}
      </p>
    </header>

    <section class="py-24 border-b border-gray-900 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-amber-900/10 via-[#050505] to-[#050505]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 rounded-full">
            {t('commercial:agpl.badge')}
          </div>
          <h2 class="text-3xl font-bold text-white mb-6">{t('commercial:agpl.title')}</h2>
          <p class="text-gray-300 text-lg leading-relaxed mb-6" set:html={t('commercial:agpl.p1')}></p>
          <p class="text-gray-300 text-lg leading-relaxed" set:html={t('commercial:agpl.p2')}></p>
        </div>

        <div class="bg-gradient-to-r from-orange-500/10 to-red-500/10 border border-orange-500/30 rounded-2xl p-8 flex flex-col md:flex-row gap-6 items-center shadow-[0_0_30px_rgba(249,115,22,0.1)]">
          <div class="flex-shrink-0 bg-orange-500/20 p-4 rounded-full text-orange-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">{t('commercial:agpl.warning_title')}</h3>
            <p class="text-gray-400 leading-relaxed">{t('commercial:agpl.warning_desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-gray-900">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-blue-400 bg-blue-400/10 border border-blue-400/20 rounded-full">
            {t('commercial:compare.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white">{t('commercial:compare.title')}</h2>
        </div>

        <div class="overflow-x-auto rounded-2xl border border-gray-800 bg-[#0a0a0a]">
          <table class="w-full text-left border-collapse min-w-[600px]">
            <thead>
              <tr class="border-b border-gray-800 bg-gray-900/50">
                <th class="p-6 w-1/3"></th>
                <th class="p-6 w-1/3 text-center border-l border-gray-800">
                  <div class="text-xl font-bold text-white">{t('commercial:compare.col1_title')}</div>
                  <div class="text-sm text-gray-500 mt-1 font-normal">{t('commercial:compare.col1_desc')}</div>
                </th>
                <th class="p-6 w-1/3 text-center border-l border-amber-500/30 bg-amber-500/5">
                  <div class="text-xl font-bold text-amber-400">{t('commercial:compare.col2_title')}</div>
                  <div class="text-sm text-amber-500/70 mt-1 font-normal">{t('commercial:compare.col2_desc')}</div>
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800 text-sm md:text-base">
              <tr>
                <td class="p-6 font-medium text-gray-300">{t('commercial:compare.f1')}</td>
                <td class="p-6 border-l border-gray-800" set:html={CheckIcon + '<span class="sr-only">Included</span>'}></td>
                <td class="p-6 border-l border-amber-500/30 bg-amber-500/5" set:html={CheckIcon + '<span class="sr-only">Included</span>'}></td>
              </tr>
              <tr>
                <td class="p-6 font-medium text-gray-300">{t('commercial:compare.f2')}</td>
                <td class="p-6 text-center border-l border-gray-800 text-blue-400 font-semibold">{t('commercial:compare.val_agpl_f2')}</td>
                <td class="p-6 text-center border-l border-amber-500/30 bg-amber-500/5 text-amber-500 font-semibold">{t('commercial:compare.val_com_f2')}</td>
              </tr>
              <tr>
                <td class="p-6 font-medium text-gray-300">{t('commercial:compare.f3')}</td>
                <td class="p-6 border-l border-gray-800" set:html={CrossIcon + '<span class="sr-only">Not included</span>'}></td>
                <td class="p-6 border-l border-amber-500/30 bg-amber-500/5" set:html={CheckIcon + '<span class="sr-only">Included</span>'}></td>
              </tr>
              <tr>
                <td class="p-6 font-medium text-gray-300">{t('commercial:compare.f4')}</td>
                <td class="p-6 border-l border-gray-800" set:html={CrossIcon + '<span class="sr-only">Not included</span>'}></td>
                <td class="p-6 border-l border-amber-500/30 bg-amber-500/5" set:html={CheckIcon + '<span class="sr-only">Included</span>'}></td>
              </tr>
              <tr>
                <td class="p-6 font-medium text-gray-300">{t('commercial:compare.f5')}</td>
                <td class="p-6 border-l border-gray-800" set:html={CrossIcon + '<span class="sr-only">Not included</span>'}></td>
                <td class="p-6 border-l border-amber-500/30 bg-amber-500/5" set:html={CheckIcon + '<span class="sr-only">Included</span>'}></td>
              </tr>
              <tr>
                <td class="p-6"></td>
                <td class="p-6 border-l border-gray-800 text-center">
                  <a href="https://github.com/h4nzs/nyx-chat" target="_blank" class="text-gray-400 hover:text-white transition-colors">View GitHub</a>
                </td>
                <td class="p-6 border-l border-amber-500/30 bg-amber-500/5 text-center">
                  <a href="mailto:admin@nyx-app.my.id" class="inline-block bg-amber-500 text-black font-bold py-2 px-6 rounded-lg hover:bg-amber-400 transition-colors w-full">
                    {t('commercial:compare.contact_sales')}
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-gray-900 bg-[#0a0a0a]">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-purple-400 bg-purple-400/10 border border-purple-400/20 rounded-full">
            {t('commercial:usecases.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white">{t('commercial:usecases.title')}</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-gray-900 border border-gray-800 p-8 rounded-2xl">
            <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400 mb-6">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{t('commercial:usecases.c1_title')}</h3>
            <p class="text-gray-400 leading-relaxed">{t('commercial:usecases.c1_desc')}</p>
          </div>
          <div class="bg-gray-900 border border-gray-800 p-8 rounded-2xl">
            <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center text-green-400 mb-6">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{t('commercial:usecases.c2_title')}</h3>
            <p class="text-gray-400 leading-relaxed">{t('commercial:usecases.c2_desc')}</p>
          </div>
          <div class="bg-gray-900 border border-gray-800 p-8 rounded-2xl">
            <div class="w-12 h-12 bg-red-500/20 rounded-xl flex items-center justify-center text-red-400 mb-6">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{t('commercial:usecases.c3_title')}</h3>
            <p class="text-gray-400 leading-relaxed">{t('commercial:usecases.c3_desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 rounded-full">
            {t('commercial:faq.badge')}
          </div>
          <h2 class="text-3xl font-bold text-white">{t('commercial:faq.title')}</h2>
        </div>

        <div class="space-y-8 mb-20">
          <div class="bg-[#0a0a0a] border border-gray-800 p-6 rounded-xl">
            <h4 class="text-lg font-bold text-white mb-2">{t('commercial:faq.q1')}</h4>
            <p class="text-gray-400">{t('commercial:faq.a1')}</p>
          </div>
          <div class="bg-[#0a0a0a] border border-gray-800 p-6 rounded-xl">
            <h4 class="text-lg font-bold text-white mb-2">{t('commercial:faq.q2')}</h4>
            <p class="text-gray-400">{t('commercial:faq.a2')}</p>
          </div>
          <div class="bg-[#0a0a0a] border border-gray-800 p-6 rounded-xl">
            <h4 class="text-lg font-bold text-white mb-2">{t('commercial:faq.q3')}</h4>
            <p class="text-gray-400">{t('commercial:faq.a3')}</p>
          </div>
        </div>

        <div class="bg-gradient-to-br from-gray-900 to-black border border-gray-800 rounded-3xl p-12 text-center shadow-2xl relative overflow-hidden">
          <div class="absolute inset-0 bg-amber-500/5"></div>
          <div class="relative z-10">
            <h2 class="text-3xl font-bold mb-4">{t('commercial:cta.title')}</h2>
            <p class="text-gray-400 text-lg mb-8 max-w-lg mx-auto">
              {t('commercial:cta.subtitle')}
            </p>
            <a href="mailto:admin@nyx-app.my.id?subject=Commercial%20License%20Inquiry" class="inline-block bg-white text-black font-semibold py-4 px-10 rounded-full hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.2)]">
              {t('commercial:cta.button')}
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</MainLayout>