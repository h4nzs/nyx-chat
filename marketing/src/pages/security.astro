---
import MainLayout from '../layouts/MainLayout.astro';
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const { lang: propLang } = Astro.props;
const lang = propLang || Astro.currentLocale || getLangFromUrl(Astro.url);
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const t = useTranslations(lang);

const title = t('security:meta.title') !== 'security:meta.title' ? t('security:meta.title') : 'Security Architecture | NYX Chat';
const description = t('security:meta.description') !== 'security:meta.description' ? t('security:meta.description') : 'Discover the zero-knowledge architecture and military-grade encryption powering NYX Chat.';

const securitySchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "NYX Security Architecture & Zero-Knowledge Protocol",
  "alternativeHeadline": "How NYX protects metadata without storing user identities",
  "author": { "@type": "Organization", "name": "NYX Project" },
  "keywords": "Signal Protocol, Argon2, Zero-Knowledge, End-to-End Encryption, Privacy, Blind Indexing",
  "articleBody": "NYX takes a radical approach to security: Trust No One (TNO). The architecture assumes servers are compromised and encrypts data locally.",
  "datePublished": "2026-03-01"
});
---

<MainLayout title={title} description={description} canonicalUrl={Astro.url.pathname} schemaMarkup={securitySchema}>
  <main class="w-full text-white bg-[#050505] font-sans selection:bg-blue-500/30">
    
    <header class="max-w-4xl mx-auto px-6 pt-32 pb-20 text-center border-b border-gray-900">
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 via-purple-500 to-cyan-400">
        {t('security:hero.title')}
      </h1>
      <p class="sr-only">
        {t('security:seo.geo_hook') !== 'security:seo.geo_hook' ? t('security:seo.geo_hook') : 'NYX Security Architecture operates on a Trust No One (TNO) model. Features include Blind Indexing via Argon2id, Signal Protocol Double Ratchet encryption for messages, local-first IndexedDB storage for chat histories, and direct WebRTC P2P tunnels bypassing servers for calls.'}
      </p>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto">
        {t('security:hero.subtitle')}
      </p>
    </header>

    <section class="py-24 border-b border-gray-900">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-red-400 bg-red-400/10 border border-red-400/20 rounded-full">
            {t('security:threat.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">{t('security:threat.title')}</h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-6" set:html={t('security:threat.p1')}></p>
          <p class="text-gray-400 text-lg leading-relaxed" set:html={t('security:threat.p2')}></p>
        </div>
        <div class="relative bg-[#0a0a0a] border border-gray-800 rounded-2xl p-8 font-mono shadow-[0_0_40px_rgba(220,38,38,0.05)]">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-red-600/20 blur-2xl rounded-full animate-pulse"></div>
          <div class="flex items-center justify-between mb-6 text-sm border-b border-gray-800 pb-4">
            <span class="text-gray-500">NYX_SERVER_DB // POSTGRES</span>
            <span class="text-red-500 font-bold flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
              BREACHED
            </span>
          </div>
          <div class="space-y-3 text-xs md:text-sm">
            <div class="flex gap-4"><span class="text-blue-500 w-12">ROW_1</span><span class="text-gray-600 truncate">e2a9f8b3... <span class="text-red-400/50">UNREADABLE</span></span></div>
            <div class="flex gap-4"><span class="text-blue-500 w-12">ROW_2</span><span class="text-gray-600 truncate">7c4d11a9... <span class="text-red-400/50">UNREADABLE</span></span></div>
            <div class="flex gap-4"><span class="text-blue-500 w-12">ROW_3</span><span class="text-gray-600 truncate">ff20x91p... <span class="text-red-400/50">UNREADABLE</span></span></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center backdrop-blur-[2px]">
            <div class="bg-gray-900 border border-gray-700 px-6 py-4 rounded-xl flex items-center gap-4 shadow-2xl">
              <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              <div class="text-left">
                <div class="text-white font-bold text-sm">Data Secured</div>
                <div class="text-green-400 text-xs">Zero-Knowledge Kept Intact</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-gray-900 bg-gray-900/10">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 relative flex flex-col items-center justify-center p-8">
          <div class="flex items-center w-full justify-between max-w-md">
            <div class="flex flex-col items-center gap-3">
              <div class="w-16 h-16 bg-blue-500/10 border border-blue-500/30 rounded-full flex items-center justify-center text-blue-400">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              </div>
              <div class="text-xs font-mono text-gray-400 text-center"><span class="text-white">Device</span><br/>@h4nzs</div>
            </div>
            <div class="flex-1 flex flex-col items-center relative">
              <div class="w-full h-[1px] bg-gradient-to-r from-blue-500/50 to-purple-500/50 absolute top-8"></div>
              <div class="z-10 w-10 h-10 bg-gray-900 border border-gray-700 rounded-lg flex items-center justify-center text-gray-300 mt-3 animate-[spin_4s_linear_infinite]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div class="text-[10px] text-purple-400 font-mono mt-2 bg-purple-400/10 px-2 py-0.5 rounded">Argon2id KDF</div>
            </div>
            <div class="flex flex-col items-center gap-3">
              <div class="w-16 h-16 bg-purple-500/10 border border-purple-500/30 rounded-full flex items-center justify-center text-purple-400">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
              </div>
              <div class="text-xs font-mono text-gray-400 text-center"><span class="text-white">NYX Server</span><br/>Hash: 9a3b...</div>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-purple-400 bg-purple-400/10 border border-purple-400/20 rounded-full">
            {t('security:blind.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">{t('security:blind.title')}</h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-6">{t('security:blind.p1')}</p>
          <p class="text-gray-400 text-lg leading-relaxed mb-6" set:html={t('security:blind.p2')}></p>
          <p class="text-gray-400 text-lg leading-relaxed">{t('security:blind.p3')}</p>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-gray-900">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-cyan-400 bg-cyan-400/10 border border-cyan-400/20 rounded-full">
            {t('security:ratchet.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">{t('security:ratchet.title')}</h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-6" set:html={t('security:ratchet.p1')}></p>
          <ul class="space-y-6 text-gray-400 text-lg">
            <li class="flex items-start gap-4">
              <svg class="w-6 h-6 text-cyan-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              <div set:html={t('security:ratchet.pfs')}></div>
            </li>
            <li class="flex items-start gap-4">
              <svg class="w-6 h-6 text-cyan-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
              <div set:html={t('security:ratchet.pcs')}></div>
            </li>
          </ul>
        </div>
        <div class="relative bg-[#0a0a0a] border border-gray-800 rounded-2xl p-8 font-mono shadow-[0_0_40px_rgba(6,182,212,0.05)] flex flex-col items-center">
          <div class="flex items-center gap-6 mb-8">
            <div class="relative flex items-center justify-center">
              <svg class="w-16 h-16 text-cyan-500 animate-[spin_4s_linear_infinite]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <div class="absolute inset-0 flex items-center justify-center text-[10px] font-bold text-white">KDF</div>
            </div>
            <div class="flex flex-col gap-2 w-48">
              <div class="bg-cyan-500/10 border border-cyan-500/30 p-2 rounded text-[10px] text-cyan-400 flex justify-between"><span>MSG #1</span> <span>KEY_A</span></div>
              <div class="bg-cyan-500/10 border border-cyan-500/30 p-2 rounded text-[10px] text-cyan-400 flex justify-between opacity-75"><span>MSG #2</span> <span>KEY_B</span></div>
              <div class="bg-cyan-500/10 border border-cyan-500/30 p-2 rounded text-[10px] text-cyan-400 flex justify-between opacity-50"><span>MSG #3</span> <span>KEY_C</span></div>
            </div>
          </div>
          <div class="w-full bg-gray-900 border border-gray-700 p-3 rounded-lg text-xs text-center text-gray-400">
            Plaintext → <span class="text-white">v2_28a9b1...c4</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-gray-900 bg-gray-900/10">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 relative flex items-center justify-center gap-8">
          <div class="flex flex-col items-center bg-[#0a0a0a] border border-emerald-500/30 rounded-2xl p-6 shadow-[0_0_30px_rgba(16,185,129,0.1)]">
            <svg class="w-12 h-12 text-emerald-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
            <div class="text-[10px] font-mono text-emerald-400 border border-emerald-400/30 bg-emerald-400/10 px-2 py-1 rounded">IndexedDB Vault</div>
          </div>
          <div class="h-[2px] w-12 bg-gray-800 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gray-900 p-1 rounded-full border border-gray-700">
              <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </div>
          </div>
          <div class="flex flex-col items-center bg-[#0a0a0a] border border-gray-800 rounded-2xl p-6 opacity-75">
            <svg class="w-12 h-12 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
            <div class="text-[10px] font-mono text-gray-500 border border-gray-800 bg-gray-800/50 px-2 py-1 rounded">Cloud DB</div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 rounded-full">
            {t('security:vault.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">{t('security:vault.title')}</h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-6" set:html={t('security:vault.p1')}></p>
          <p class="text-gray-400 text-lg leading-relaxed" set:html={t('security:vault.p2')}></p>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-gray-900">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-orange-400 bg-orange-400/10 border border-orange-400/20 rounded-full">
            {t('security:webrtc.badge')}
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">{t('security:webrtc.title')}</h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-6" set:html={t('security:webrtc.p1')}></p>
          <p class="text-gray-400 text-lg leading-relaxed" set:html={t('security:webrtc.p2')}></p>
        </div>
        <div class="relative bg-[#0a0a0a] border border-gray-800 rounded-2xl p-8 shadow-[0_0_40px_rgba(249,115,22,0.05)] flex items-center justify-center min-h-[250px] overflow-hidden">
          <div class="absolute left-8 flex flex-col items-center">
            <div class="w-12 h-12 bg-gray-900 rounded-full border border-gray-700 flex items-center justify-center z-10">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <span class="text-[10px] text-gray-500 mt-2 font-mono">Peer A</span>
          </div>
          <div class="absolute top-8 flex flex-col items-center opacity-30">
            <div class="w-10 h-10 bg-gray-900 rounded-lg border border-gray-800 flex items-center justify-center">
              <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
            </div>
            <span class="text-[10px] text-gray-600 mt-2 font-mono line-through">Server Bypassed</span>
          </div>
          <div class="absolute right-8 flex flex-col items-center">
            <div class="w-12 h-12 bg-gray-900 rounded-full border border-gray-700 flex items-center justify-center z-10">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <span class="text-[10px] text-gray-500 mt-2 font-mono">Peer B</span>
          </div>
          <div class="w-full px-20">
            <div class="relative w-full h-[2px] bg-orange-500/20 overflow-hidden rounded-full">
              <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-transparent via-orange-400 to-transparent animate-[webrtcFlow_2s_linear_infinite]"></div>
            </div>
            <div class="text-center mt-3 text-[10px] font-mono text-orange-400 font-bold tracking-widest">
              DIRECT P2P TUNNEL
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="bg-gradient-to-b from-gray-900 to-[#050505] border border-gray-800 rounded-3xl p-12 shadow-2xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('security:cta.title')}</h2>
          <p class="text-gray-400 text-lg mb-8 max-w-xl mx-auto">
            {t('security:cta.subtitle')}
          </p>
          <a href="https://github.com/h4nzs/nyx-chat/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-black font-semibold py-4 px-8 rounded-full hover:bg-gray-200 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.2)]">
            {t('security:cta.button')}
          </a>
        </div>
      </div>
    </section>
    
  </main>
</MainLayout>

<style>
  @keyframes webrtcFlow {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(300%); }
  }
</style>