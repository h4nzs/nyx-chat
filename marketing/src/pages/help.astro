---
import MainLayout from '../layouts/MainLayout.astro';
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { 
  FiChevronLeft, FiHelpCircle, FiRefreshCw, 
  FiUserCheck, FiKey, FiCloudOff, FiAlertCircle,
  FiShield, FiZap
} from 'react-icons/fi';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('help:title');
const description = "Knowledge base for NYX: learn about secure account migration, sandbox mode, and zero-knowledge architecture.";

const categories = [
  { id: 'migration', icon: FiRefreshCw, title: t('help:move_account.title') },
  { id: 'sandbox', icon: FiUserCheck, title: t('help:sandbox_mode.title') },
  { id: 'password', icon: FiKey, title: t('help:forgot_password.title') },
  { id: 'sync', icon: FiCloudOff, title: t('help:sync_issues.title') },
  { id: 'lost', icon: FiAlertCircle, title: t('help:lost_phrase.title') },
];
---

<MainLayout title={title} description={description} canonicalUrl={Astro.url.pathname}>
  <div class="min-h-screen bg-bg-main text-text-primary p-4 md:p-8">
    <div class="max-w-4xl mx-auto">
      
      <nav class="flex items-center gap-2 text-xs font-bold text-text-secondary uppercase tracking-widest mb-8 animate-in fade-in duration-500">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span>/</span>
        <span class="text-accent">{title}</span>
      </nav>

      <div class="flex flex-col md:flex-row gap-12">
        
        <aside class="md:w-64 flex-shrink-0 hidden md:block">
          <div class="sticky top-8 bg-bg-surface rounded-2xl p-6 border border-white/5 shadow-neu-flat-dark">
            <h3 class="text-sm font-black uppercase tracking-tighter mb-4 flex items-center gap-2">
              <FiHelpCircle class="text-accent" /> Topics
            </h3>
            <nav class="space-y-1">
              {categories.map(cat => (
                <a href={`#${cat.id}`} class="block py-2 text-sm text-text-secondary hover:text-accent transition-colors font-medium border-l-2 border-transparent hover:border-accent pl-2">
                  {cat.title}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <div class="flex-1 space-y-16">
          <header class="mb-12 border-b border-white/5 pb-8 animate-in slide-in-from-bottom-4 duration-700">
            <h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 bg-gradient-to-r from-white to-text-secondary bg-clip-text text-transparent">{title}</h1>
            <p class="text-lg text-text-secondary leading-relaxed">
              Panduan teknis dan operasional untuk ekosistem NYX yang aman dan terenkripsi.
            </p>
          </header>

          <section id="migration" class="scroll-mt-24 group">
            <div class="flex items-center gap-3 mb-6">
              <div class="p-3 rounded-xl bg-accent/10 text-accent group-hover:scale-110 transition-transform shadow-[inset_2px_2px_5px_rgba(0,0,0,0.2)]">
                <FiRefreshCw size={24} />
              </div>
              <h2 class="text-2xl font-bold tracking-tight">{t('help:move_account.title')}</h2>
            </div>
            <div class="bg-bg-surface p-6 rounded-2xl border border-white/5 text-text-secondary shadow-sm">
              <p class="mb-6">{t('help:move_account.desc')}</p>
              <div class="grid sm:grid-cols-2 gap-4">
                <div class="bg-black/20 p-5 rounded-xl border border-white/5">
                  <h4 class="text-text-primary font-bold mb-2 flex items-center gap-2 italic"><FiZap class="text-yellow-500" /> 1. Jalur Cepat (QR)</h4>
                  <p class="text-sm">Gunakan fitur <code class="text-accent">Transfer to New Device</code> untuk migrasi langsung antar perangkat via P2P Tunnel.</p>
                </div>
                <div class="bg-black/20 p-5 rounded-xl border border-white/5">
                  <h4 class="text-text-primary font-bold mb-2 flex items-center gap-2 italic"><FiShield class="text-blue-500" /> 2. Jalur Vault</h4>
                  <p class="text-sm">Ekspor file <code class="text-accent">.nyxvault</code> terenkripsi dan impor kembali di perangkat baru mana pun.</p>
                </div>
              </div>
            </div>
          </section>

          <section id="sandbox" class="scroll-mt-24 group">
            <div class="flex items-center gap-3 mb-6">
              <div class="p-3 rounded-xl bg-accent/10 text-accent group-hover:scale-110 transition-transform shadow-[inset_2px_2px_5px_rgba(0,0,0,0.2)]">
                <FiUserCheck size={24} />
              </div>
              <h2 class="text-2xl font-bold tracking-tight">{t('help:sandbox_mode.title')}</h2>
            </div>
            <div class="bg-bg-surface p-6 rounded-2xl border border-white/5 text-text-secondary">
              <p class="mb-4">NYX menggunakan sistem <strong class="text-text-primary">Proof-of-Humanity</strong> untuk mencegah bot tanpa mengambil data pribadi pengguna (seperti nomor telepon).</p>
              <div class="flex flex-col gap-3">
                <div class="flex gap-4 items-start p-4 bg-accent/5 rounded-xl border border-accent/10">
                  <span class="px-2 py-1 bg-accent text-white text-[10px] font-black rounded uppercase mt-1">Update</span>
                  <p class="text-sm m-0">Tingkatkan ke <strong>VIP Status</strong> secara instan melalui Verifikasi Biometrik atau kriptografi <em>Proof of Work</em> di menu Settings.</p>
                </div>
              </div>
            </div>
          </section>

          <section id="password" class="scroll-mt-24 group">
            <div class="flex items-center gap-3 mb-6">
              <div class="p-3 rounded-xl bg-yellow-500/10 text-yellow-500 group-hover:scale-110 transition-transform shadow-[inset_2px_2px_5px_rgba(0,0,0,0.2)]">
                <FiKey size={24} />
              </div>
              <h2 class="text-2xl font-bold tracking-tight">{t('help:forgot_password.title')}</h2>
            </div>
            <div class="bg-yellow-500/5 border border-yellow-500/20 p-6 rounded-2xl relative overflow-hidden">
               <div class="absolute -right-4 -top-4 opacity-10"><FiKey size={120} /></div>
               <p class="text-yellow-200/80 mb-6 italic leading-relaxed">
                 Karena arsitektur Zero-Knowledge, NYX tidak menyimpan kunci Anda. Kami tidak bisa memulihkan akun lewat email atau SMS.
               </p>
               <ol class="space-y-4 text-text-secondary">
                 <li class="flex gap-4">
                   <span class="flex-shrink-0 w-6 h-6 bg-yellow-500 text-black flex items-center justify-center rounded-full font-black text-xs">1</span>
                   <span>Masukkan 24 kata <strong class="text-text-primary italic">Recovery Phrase</strong> Anda pada layar login.</span>
                 </li>
                 <li class="flex gap-4">
                   <span class="flex-shrink-0 w-6 h-6 bg-yellow-500 text-black flex items-center justify-center rounded-full font-black text-xs">2</span>
                   <span>Tentukan <em>Master Password</em> baru untuk mengenkripsi database lokal Anda.</span>
                 </li>
               </ol>
            </div>
          </section>

          <section id="sync" class="scroll-mt-24 group">
            <div class="flex items-center gap-3 mb-6">
              <div class="p-3 rounded-xl bg-accent/10 text-accent group-hover:scale-110 transition-transform shadow-[inset_2px_2px_5px_rgba(0,0,0,0.2)]">
                <FiCloudOff size={24} />
              </div>
              <h2 class="text-2xl font-bold tracking-tight">{t('help:sync_issues.title')}</h2>
            </div>
            <div class="bg-bg-surface p-6 rounded-2xl border border-white/5 text-text-secondary leading-relaxed">
              <p class="mb-4">NYX mengusung filosofi <strong class="text-text-primary text-accent">Local-First</strong>. Pesan Anda hidup di perangkat Anda, bukan di cloud kami.</p>
              <div class="p-4 bg-black/20 rounded-xl border-l-4 border-accent">
                <p class="text-sm m-0 italic">{t('help:sync_issues.desc')}</p>
              </div>
              <p class="mt-4 text-sm opacity-60 font-mono italic">// {t('help:sync_issues.future_text')}</p>
            </div>
          </section>

          <section id="lost" class="scroll-mt-24 group">
            <div class="flex items-center gap-3 mb-6">
              <div class="p-3 rounded-xl bg-red-500/10 text-red-500 group-hover:scale-110 transition-transform shadow-[inset_2px_2px_5px_rgba(0,0,0,0.2)]">
                <FiAlertCircle size={24} />
              </div>
              <h2 class="text-2xl font-bold tracking-tight text-red-400">{t('help:lost_phrase.title')}</h2>
            </div>
            <div class="bg-red-500/5 border border-red-500/20 p-6 rounded-2xl">
              <h4 class="text-red-400 font-black uppercase tracking-tighter mb-2 italic">⚠️ STATUS: {t('help:lost_phrase.irrecoverable')}</h4>
              <p class="text-text-secondary leading-relaxed m-0">{t('help:lost_phrase.desc')}</p>
            </div>
          </section>

        </div>
      </div>

      <footer class="mt-20 pt-8 border-t border-white/5 text-center text-text-secondary">
        <p class="text-xs uppercase tracking-[0.2em] font-bold opacity-30">NYX Intelligence Base &bull; Security Level 0</p>
      </footer>
    </div>
  </div>
</MainLayout>