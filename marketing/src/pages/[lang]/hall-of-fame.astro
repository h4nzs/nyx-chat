---
import '../../index.css';
import BaseHallOfFame from '../hall-of-fame.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
    { params: { lang: 'pt-BR' } },
  ];
}

const { lang } = Astro.params;
---
<BaseHallOfFame lang={lang} />
