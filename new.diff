+
+export function hoistConvoKeys(convo: RawConversationData): any {
+  return {
+    ...convo,
+    participants: convo.participants?.map(p => ({
+      ...p,
+      user: p.user ? hoistKeys(p.user as UserWithDevices) : null
+    }))
+  };
+}
